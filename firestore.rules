rules_version = '2';

// ============================================================
//  Reglas de seguridad de Firestore · POLIMARA
//  Proyecto: polimaradvt
//  Control de vehículos retenidos (comandancia)
// ============================================================
//
//  Cómo publicarlas:
//   A) Consola web: Firebase Console → Firestore Database → pestaña
//      "Reglas" → pega este contenido → "Publicar".
//   B) CLI:  firebase deploy --only firestore:rules
//
//  IMPORTANTE (protección de datos):
//   - Se permite LEER, CREAR y ACTUALIZAR registros.
//   - Se PROHÍBE BORRAR: ningún registro puede eliminarse desde la app,
//     de modo que no se pierda ningún dato. Las correcciones se hacen
//     por actualización (y quedan asentadas en el historial de novedades).
//
//  RECOMENDADO para producción en la comandancia:
//   Restringir el acceso a usuarios autenticados. Más abajo se deja el
//   bloque listo para activar Firebase Authentication (ver README).
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Colección de vehículos retenidos ----
    match /vehiculos/{id} {
      allow read:           if true;
      allow create, update: if true;
      allow delete:         if false;   // no se puede eliminar ningún registro
    }

    // ---- Todo lo demás: denegado ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ------------------------------------------------------------
//  VERSIÓN RECOMENDADA (con inicio de sesión)
//  Cuando se habilite Firebase Authentication, reemplazar el bloque
//  de /vehiculos por este, para que solo el personal autorizado
//  con sesión iniciada pueda leer y registrar:
//
//    match /vehiculos/{id} {
//      allow read, create, update: if request.auth != null;
//      allow delete:               if false;
//    }
// ------------------------------------------------------------
