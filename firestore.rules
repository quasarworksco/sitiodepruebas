rules_version = '2';

// ============================================================
//  Reglas de seguridad de Firestore · POLIMARA
//  Proyecto: polimaradvt · Control de vehículos retenidos
// ============================================================
//
//  Cómo publicarlas:
//   A) Consola web: Firebase Console → Firestore Database → "Reglas"
//      → pega este contenido → "Publicar".
//   B) CLI:  firebase deploy --only firestore:rules
//
//  Seguridad:
//   - Solo el personal con SESIÓN INICIADA (Firebase Authentication)
//     puede leer y registrar. Sin sesión no hay acceso a los datos.
//   - Se PROHÍBE BORRAR: ningún registro puede eliminarse, para no
//     perder datos. Las correcciones se hacen por actualización.
//
//  Requisitos en la consola (una sola vez):
//   1) Firestore Database → Crear base de datos (modo producción).
//   2) Authentication → Sign-in method → habilitar "Correo/Contraseña".
//   3) Crear la primera cuenta desde la propia app (pestaña "Crear
//      cuenta" + código de registro) o en Authentication → Users.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Vehículos retenidos ----
    match /vehiculos/{id} {
      allow read, create, update: if request.auth != null;  // requiere sesión
      allow delete:               if false;                 // nunca se elimina
    }

    // ---- Todo lo demás: denegado ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
